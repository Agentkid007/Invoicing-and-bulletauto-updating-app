# ─── BulletAuto Backend — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in the values before starting the server.

# Server port (default: 4000)
PORT=4000

# Path to SQLite database file (default: ./bulletauto.db)
DATABASE_PATH=./bulletauto.db

# JWT signing secret — CHANGE THIS in production!
JWT_SECRET=bulletauto-secret-key-change-me

# Company banking details shown on every invoice
BANK_NAME=FNB
BANK_BRANCH=251945 (Cape Gate)
BANK_ACCOUNT=62831852274
BANK_COMPANY=BULLET RAJA AGENCY (Pty) Ltd
