{
  "name": "bulletauto",
  "version": "2.0.0",
  "description": "BulletAuto — Invoicing & Service-Booking Desktop App",
  "author": "Bullet Auto Performance <admin@bulletauto.co.za>",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "_comment_individual": "── Individual service launchers ──────────────────────────────────────────",
    "start-backend": "npm --prefix backend start",
    "dev-backend":   "npm --prefix backend run dev",
    "start-client":  "npm --prefix client run dev",
    "start-electron":"wait-on http://localhost:3000 http://localhost:4000 && electron .",

    "_comment_combined": "── Combined launchers (use these day-to-day) ─────────────────────────────",
    "dev": "concurrently --kill-others-on-fail --prefix-colors \"bgBlue.bold,bgGreen.bold\" --names \"BACKEND,CLIENT\" \"npm run dev-backend\" \"npm run start-client\"",
    "dev:all": "concurrently --kill-others-on-fail --prefix-colors \"bgBlue.bold,bgGreen.bold,bgMagenta.bold\" --names \"BACKEND,CLIENT,ELECTRON\" \"npm run dev-backend\" \"npm run start-client\" \"npm run start-electron\"",
    "start:all": "concurrently --kill-others-on-fail --prefix-colors \"bgBlue.bold,bgGreen.bold,bgMagenta.bold\" --names \"BACKEND,CLIENT,ELECTRON\" \"npm run start-backend\" \"npm run start-client\" \"npm run start-electron\"",

    "_comment_build": "── Build & packaging ─────────────────────────────────────────────────────",
    "build:client":   "npm --prefix client run build",
    "electron-build": "npm run build:client && electron-builder --win --x64",
    "desktop:dev":    "npm run dev:all",
    "desktop:build":  "npm run electron-build",

    "_comment_mobile": "── Mobile (Expo / React Native) ──────────────────────────────────────────",
    "mobile:start":   "npm --prefix mobile start",
    "android":        "npm --prefix mobile run android",
    "ios":            "npm --prefix mobile run ios",

    "_comment_install": "── One-shot dependency install for all sub-packages ──────────────────────",
    "install:all": "npm install && npm --prefix backend install && npm --prefix client install && npm --prefix mobile install"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^28.2.0",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "co.bulletauto.app",
    "productName": "BulletAuto",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "client/dist/**/*",
      "backend/**/*",
      "!backend/node_modules/**/*",
      "!**/node_modules/**/.cache/**"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*", "!node_modules"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BulletAuto"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/assets/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "Agentkid007",
      "repo": "Invoicing-and-bulletauto-updating-app"
    }
  }
}
